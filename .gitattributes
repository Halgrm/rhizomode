# Default: auto-detect, but normalize to LF in repo
* text=auto eol=lf

# Unity text assets — explicit LF (prevents line-ending churn → AssetDB refresh storms)
*.cs        text eol=lf diff=csharp
*.asmdef    text eol=lf
*.asmref    text eol=lf
*.shader    text eol=lf
*.hlsl      text eol=lf
*.compute   text eol=lf
*.uxml      text eol=lf
*.uss       text eol=lf
*.unity     text eol=lf merge=unityyamlmerge
*.prefab    text eol=lf merge=unityyamlmerge
*.asset     text eol=lf merge=unityyamlmerge
*.meta      text eol=lf merge=unityyamlmerge
*.mat       text eol=lf merge=unityyamlmerge
*.anim      text eol=lf merge=unityyamlmerge
*.controller    text eol=lf merge=unityyamlmerge
*.physicMaterial text eol=lf merge=unityyamlmerge
*.physicsMaterial2D text eol=lf merge=unityyamlmerge
*.lighting  text eol=lf merge=unityyamlmerge
*.spriteatlas text eol=lf merge=unityyamlmerge
*.terrainlayer text eol=lf merge=unityyamlmerge
*.preset    text eol=lf merge=unityyamlmerge

# JSON / config
*.json      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.xml       text eol=lf

# Binaries — never convert
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.psd       binary
*.tga       binary
*.tif       binary
*.tiff      binary
*.bmp       binary
*.exr       binary
*.hdr       binary
*.fbx       binary
*.obj       binary
*.blend     binary
*.wav       binary
*.mp3       binary
*.ogg       binary
*.aif       binary
*.aiff      binary
*.mp4       binary
*.mov       binary
*.webm      binary
*.dll       binary
*.so        binary
*.dylib     binary
*.pdb       binary
*.unitypackage binary
*.zip       binary
*.tar.gz    binary
*.7z        binary
*.ttf       binary
*.otf       binary

# Unity LFS candidates (if LFS later)
*.vfx       text eol=lf
